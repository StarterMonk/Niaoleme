{
  "expo": {
    "name": "尿了么 Niaoleme",
    "slug": "niaoleme-health-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5FB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF5FB"
      },
      "package": "com.jimmyhao.urinehealthapp",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-document-picker"
    ],
    "extra": {
      "eas": {}
    },
    "description": "尿了么 - AI驱动的健康管理应用，追踪健康指标、发现附近厕所、获取AI健康建议"
  }
}
